# QA Framework credentials — copy this file to `.env` and fill in real values.
#   Copy-Item .env.example .env
# `.env` is GIT-IGNORED and loaded at runtime by scripts/load_env.ps1 (no restart needed).
# Use TEST / non-production accounts only — this is plaintext on disk.

# Azure DevOps Personal Access Token (scopes: Work Items Read & Write)
AZURE_DEVOPS_PAT=

# One account per role — keys must match the roles in docs/ai/test-data-policy.md
QA_ADMIN_USER=
QA_ADMIN_PASS=
QA_MANAGER_USER=
QA_MANAGER_PASS=
QA_SUPERVISOR_USER=
QA_SUPERVISOR_PASS=
QA_VIEWER_USER=
QA_VIEWER_PASS=
